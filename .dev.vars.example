# Copy to ".dev.vars" for local development with `wrangler pages dev`.
# ".dev.vars" is gitignored — never commit real secrets.
# In production, set these in the Pages dashboard (Settings → Environment
# variables / Secrets), NOT in this file.

# Resend API key (secret) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender on your Resend-verified domain.
RESEND_FROM=Skyline <quotes@skylineexteriorcleaning.com>

# Where leads are emailed (your real inboxes). May be the same address to start.
RESIDENTIAL_INBOX=quotes@skylineexteriorcleaning.com
COMMERCIAL_INBOX=quotes@skylineexteriorcleaning.com
